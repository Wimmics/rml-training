@prefix rr: <http://www.w3.org/ns/r2rml#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix fnml: <http://semweb.mmlab.be/ns/fnml#>.
@prefix fno: <https://w3id.org/function/ontology#>.
@prefix d2rq: <http://www.wiwiss.fu-berlin.de/suhl/bizer/D2RQ/0.1#>.
@prefix void: <http://rdfs.org/ns/void#>.
@prefix dc: <http://purl.org/dc/terms/>.
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix rml: <http://semweb.mmlab.be/ns/rml#>.
@prefix ql: <http://semweb.mmlab.be/ns/ql#>.
@prefix : <http://mapping.example.com/>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix grel: <http://users.ugent.be/~bjdmeest/function/grel.ttl#>.
@prefix idlab: <https://w3id.org/imec/idlab/function#>.
@prefix devinfra: <http://w3id.org/devops-infra/server#>.
@prefix noria: <https://w3id.org/noria/ontology/>.
@prefix ex: <http://example.com/data/>.

:rules_000 a void:Dataset;
    void:exampleResource :map_ServerMap_verbose_000.
:map_ServerMap_verbose_000 rml:logicalSource :source_000.
:source_000 a rml:LogicalSource;
    rml:source "input_server.json";
    rml:iterator "$.servers.*";
    rml:referenceFormulation ql:JSONPath.
:map_ServerMap_verbose_000 a rr:TriplesMap;
    rdfs:label "ServerMap_verbose".
:s_000 a rr:SubjectMap.
:map_ServerMap_verbose_000 rr:subjectMap :s_000.
:s_000 rr:template "http://example.com/server-long/{$.id}".
:pom_000 a rr:PredicateObjectMap.
:map_ServerMap_verbose_000 rr:predicateObjectMap :pom_000.
:pm_000 a rr:PredicateMap.
:pom_000 rr:predicateMap :pm_000.
:pm_000 rr:constant rdf:type.
:pom_000 rr:objectMap :om_000.
:om_000 a rr:ObjectMap;
    rr:constant "http://w3id.org/devops-infra/server#Server";
    rr:termType rr:Literal.
:pom_001 a rr:PredicateObjectMap.
:map_ServerMap_verbose_000 rr:predicateObjectMap :pom_001.
:pm_001 a rr:PredicateMap.
:pom_001 rr:predicateMap :pm_001.
:pm_001 rr:constant devinfra:hostname.
:pom_001 rr:objectMap :om_001.
:om_001 a fnml:FunctionTermMap;
    rr:termType rr:Literal;
    fnml:functionValue :fn_000.
:fn_000 rml:logicalSource :source_000;
    rr:predicateObjectMap :pomexec_000.
:pomexec_000 rr:predicateMap :pmexec_000.
:pmexec_000 rr:constant fno:executes.
:pomexec_000 rr:objectMap :omexec_000.
:omexec_000 rr:constant "http://users.ugent.be/~bjdmeest/function/grel.ttl#toLowerCase";
    rr:termType rr:IRI.
:fn_000 rr:predicateObjectMap :pom_002.
:pom_002 a rr:PredicateObjectMap;
    rr:predicateMap :pm_002.
:pm_002 a rr:PredicateMap;
    rr:constant grel:valueParameter.
:pom_002 rr:objectMap :om_002.
:om_002 a rr:ObjectMap;
    rml:reference "$.hostname";
    rr:termType rr:Literal.
:pom_003 a rr:PredicateObjectMap.
:map_ServerMap_verbose_000 rr:predicateObjectMap :pom_003.
:pm_003 a rr:PredicateMap.
:pom_003 rr:predicateMap :pm_003.
:pm_003 rr:constant devinfra:ip.
:pom_003 rr:objectMap :om_003.
:om_003 a rr:ObjectMap;
    rml:reference "$.ipv4";
    rr:termType rr:Literal.
