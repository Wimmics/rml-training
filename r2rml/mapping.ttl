@prefix rdf:        <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs:       <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd:        <http://www.w3.org/2001/XMLSchema#> .
@prefix rr:         <http://www.w3.org/ns/r2rml#> .

@prefix devinfra:   <http://w3id.org/devops-infra/server#> .
@prefix noria:      <https://w3id.org/noria/ontology/> .


<#ServerMap>
  a rr:TriplesMap;
  rr:logicalTable [ rr:tableName "Server" ];
  rr:subjectMap [
    rr:template "http://example.com/server/{id}";
    rr:class    devinfra:Server;
  ];
  rr:predicateObjectMap [
    rr:predicate devinfra:hostname;
    rr:objectMap [ rr:column "hostname" ];
  ];
  rr:predicateObjectMap [
    rr:predicate devinfra:ip;
    rr:objectMap [ rr:column "ipv4"; rr:datatype xsd:string ];
  ].

<#NICMap>
  a rr:TriplesMap;
  rr:logicalTable [ rr:tableName "NetworkInterface" ];
  rr:subjectMap [
    rr:template "http://example.com/nic/{id}";
    rr:class noria:NetworkInterface;
  ];  
  rr:predicateObjectMap [
    rr:predicate rdfs:label;
    rr:objectMap [ rr:column "name" ];
  ];
  rr:predicateObjectMap [
    rr:predicate noria:networkInterfaceOperationalStatus;
    rr:objectMap [ rr:column "status" ];
  ];
  rr:predicateObjectMap [
    rr:predicate noria:networkInterfaceOf;
    rr:objectMap [
      rr:parentTriplesMap <#ServerMap>;
      rr:joinCondition [
        rr:child "server_id";
        rr:parent "id"
      ]
    ]
  ].
