@prefix rdf:        <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs:       <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd:        <http://www.w3.org/2001/XMLSchema#> .
@prefix rr:         <http://www.w3.org/ns/r2rml#> .
@prefix rml: 	    <http://semweb.mmlab.be/ns/rml#> .
@prefix ql: 	    <http://semweb.mmlab.be/ns/ql#> .

@prefix fnml:       <http://semweb.mmlab.be/ns/fnml#> .
@prefix fno: 	    <https://w3id.org/function/ontology#> .
@prefix grel:       <http://users.ugent.be/~bjdmeest/function/grel.ttl#> .
@prefix idlab:      <https://w3id.org/imec/idlab/function#> .

@prefix devinfra:   <http://w3id.org/devops-infra/server#> .
@prefix noria:      <https://w3id.org/noria/ontology/> .

@prefix ex:         <http://example.com/data/> .
@base               <http://example.org/> .

<#ServerMap> a rr:TriplesMap;
  rml:logicalSource [
    rml:source "input_server.json";
    rml:referenceFormulation ql:JSONPath;
    rml:iterator "$.servers.*";
  ];
  rr:subjectMap [
    rr:template "http://example.com/server/{$.id}";
    rr:class devinfra:Server;
  ];
  rr:predicateObjectMap [
    rr:predicate devinfra:hostname;
    rr:objectMap [
        fnml:functionValue [
            rr:predicateObjectMap [
                rr:predicate fno:executes;
                rr:object grel:toLowerCase
            ] ;
            rr:predicateObjectMap [
                rr:predicate grel:valueParameter;
                rr:objectMap [ rml:reference "$.hostname" ]
            ] ;
        ];
    ];
  ].


<#NICMap>
  rml:logicalSource [
    rml:source "input_nic.csv";
    rml:referenceFormulation ql:CSV;
  ];
  rr:subjectMap [
    rr:template "http://example.com/nic/{id}";
    rr:class noria:NetworkInterface;
  ];
  
  rr:predicateObjectMap [
    rr:predicate noria:networkInterfaceOperationalStatus;
    
    # If status=="up" then res:OperationalState/enabled else res:OperationalState/disabled
    rr:objectMap [
      fnml:functionValue [
        rr:predicateObjectMap [rr:predicate fno:executes ; rr:object grel:controls_if ];
        rr:predicateObjectMap [
          rr:predicate grel:bool_b ;
          rr:objectMap [
            fnml:functionValue [
              rr:predicateObjectMap [ rr:predicate fno:executes; rr:object idlab:equal ];
              rr:predicateObjectMap [
                rr:predicate grel:valueParameter;
                rr:objectMap [ rml:reference "status" ];
              ];
              rr:predicateObjectMap [
                rr:predicate grel:valueParameter2;
                rr:objectMap [ rr:constant "up" ];
              ];
            ];
            rr:datatype xsd:boolean
          ];
        ];
        rr:predicateObjectMap [
          rr:predicate grel:any_true ;
          rr:object <https://w3id.org/noria/kos/Resource/OperationalState/enabled> ;
        ];
        rr:predicateObjectMap [
          rr:predicate grel:any_false ;
          rr:object <https://w3id.org/noria/kos/Resource/OperationalState/disabled> ;
        ];
      ];
    ];
  ].
