# This mapping is not supported in RMLMapper 7.3.3

@prefix rdf:        <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs:       <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd:        <http://www.w3.org/2001/XMLSchema#> .
@prefix rr:         <http://www.w3.org/ns/r2rml#> .
#@prefix rml: 	    <http://semweb.mmlab.be/ns/rml#> .
@prefix rml:        <http://w3id.org/rml/> .
@prefix ql: 	      <http://semweb.mmlab.be/ns/ql#> .

@prefix grel:       <http://users.ugent.be/~bjdmeest/function/grel.ttl#> .

@prefix devinfra:   <http://w3id.org/devops-infra/server#> .
@prefix noria:      <https://w3id.org/noria/ontology/> .

@prefix ex:         <http://example.com/data/> .
@base               <http://example.org/> .

<#ServerMap> a rr:TriplesMap;
  rml:logicalSource [
    rml:source "input_server.json";
    rml:referenceFormulation ql:JSONPath;
    rml:iterator "$.servers.*";
  ];
  rr:subjectMap [
    rr:template "http://example.com/server/{$.id}";
    rr:class devinfra:Server;
  ];
  rr:predicateObjectMap [
    rr:predicate devinfra:hostname;
    rml:objectMap [               
        rml:functionExecution [
            rml:function grel:toUppercase ;
            rml:input [
                rml:parameter grel:valueParameter ;
                rml:inputValueMap [ rml:reference "$.hostname" ]
            ] ;
        ] ;
    ];
  ];
  rr:predicateObjectMap [
    rr:predicate devinfra:ip;
    rr:objectMap [ rml:reference "$.ipv4" ];
  ].
  