@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#>.
@prefix rr:     <http://www.w3.org/ns/r2rml#>.
@prefix rml: 	<http://semweb.mmlab.be/ns/rml#>.
@prefix ql: 	<http://semweb.mmlab.be/ns/ql#>.

@prefix schema: <http://schema.org/>.
@base           <http://example.org/>.


<#TM>
    a rr:TriplesMap;
    rml:logicalSource [
        rml:source  "https://api.deezer.com/search/album?q=eminem";
        rml:referenceFormulation ql:JSONPath;
        rml:iterator "$.data.*";
    ];
    rr:subjectMap [
        rr:template "http://data.deezer.com/album/{$.id}";
        rr:class    schema:MusicAlbum;
    ];
    rr:predicateObjectMap [
        rr:predicate schema:name;
        rr:objectMap [ rml:reference "$.title" ];
    ];
    rr:predicateObjectMap [
        rr:predicate schema:mainEntityOfPage;
        rr:objectMap [ rml:reference "$.link" ];
    ];
    rr:predicateObjectMap [
        rr:predicate schema:byArtist;
        rr:objectMap [ rml:reference "$.artistName" ];
    ]
    .
